# Sample .env for local development.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- Local shared MariaDB ----------------------------------------------------
# Connection password for the shared MariaDB container (`mariadb` on the
# `trefry-network` Docker network). The user is `root` by default.
#
# Used by docker-compose to assemble CODEFLOW_DB_CONNECTION_STRING for the
# api/worker containers; for `dotnet ef` from the host, set
# CODEFLOW_DB_CONNECTION_STRING explicitly (this var alone won't pick it up).
CODEFLOW_DB_PASSWORD=change_me

# Optional: override the DB user. Defaults to `root`.
# CODEFLOW_DB_USER=codeflow

# --- Secrets / API keys ------------------------------------------------------
# Master key for the encrypted-secrets store. Generate with `openssl rand -base64 32`.
Secrets__MasterKey=

# LLM provider keys. Leave blank to disable a provider.
OpenAI__ApiKey=
Anthropic__ApiKey=
