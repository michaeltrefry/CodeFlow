{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Auth": {
    "DevelopmentBypass": true,
    "RequireHttpsMetadata": false
  },
  "McpEndpointPolicy": {
    "AllowInternalTargets": true,
    "AllowedSchemes": [ "http", "https" ]
  },
  "Secrets": {
    "MasterKey": ""
  }
}
