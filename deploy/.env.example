# CodeFlow production .env example. Copy to .env.release on the Linode host (the GitHub Actions
# deploy workflow generates this automatically from secrets — see Slice 6). NEVER commit a populated
# copy of this file.

# --- Image tags (set by GitHub Actions; pin to a specific sha-<short> for rollbacks). ---
CODEFLOW_API_IMAGE=ghcr.io/michaeltrefry/codeflow-api:latest
CODEFLOW_WORKER_IMAGE=ghcr.io/michaeltrefry/codeflow-worker:latest
CODEFLOW_UI_IMAGE=ghcr.io/michaeltrefry/codeflow-ui:latest
CODEFLOW_SANDBOX_CONTROLLER_IMAGE=ghcr.io/michaeltrefry/codeflow-sandbox-controller:latest

# --- Public origin (used for CORS allow-list). ---
CODEFLOW_PUBLIC_ORIGIN=https://codeflow.trefry.net

# --- Auth: Keycloak realm at identity.trefry.net (see docs/deployment-keycloak.md). ---
CODEFLOW_AUTH_AUTHORITY=https://identity.trefry.net/realms/trefry
CODEFLOW_AUTH_AUDIENCE=codeflow-api
CODEFLOW_OAUTH_CLIENT_ID=codeflow-ui
CODEFLOW_OAUTH_SCOPE=openid profile email

# --- Persistence: shared MariaDB on trefry-network (hostname `mariadb`). ---
# DBA must create the `codeflow` database and `codeflow` user before first deploy.
CODEFLOW_DB_CONNECTION_STRING=Server=mariadb;Port=3306;Database=codeflow;User=codeflow;Password=__set_me__;

# --- Bus: shared RabbitMQ at mqapps.trefry.net. ---
# Operator must create the vhost (e.g. `codeflow`) and a service user with permissions on it.
CODEFLOW_RABBITMQ_HOST=mqapps.trefry.net
CODEFLOW_RABBITMQ_PORT=5672
CODEFLOW_RABBITMQ_MANAGEMENT_PORT=15672
CODEFLOW_RABBITMQ_VHOST=codeflow
CODEFLOW_RABBITMQ_USERNAME=codeflow
CODEFLOW_RABBITMQ_PASSWORD=__set_me__

# --- Secrets master key (AES-GCM, 32-byte base64). Generate with:
#       openssl rand -base64 32
CODEFLOW_SECRETS_MASTER_KEY=__base64-32-bytes__

# --- Optional model API keys (omit to leave the providers unconfigured). ---
CODEFLOW_OPENAI_API_KEY=
CODEFLOW_ANTHROPIC_API_KEY=

# --- Optional observability ---
CODEFLOW_OTLP_ENDPOINT=

# --- Host-side knobs (rarely changed) ---
CODEFLOW_API_HOST_PORT=5080
CODEFLOW_UI_HOST_PORT=4280
CODEFLOW_ARTIFACTS_DIR=/opt/codeflow/artifacts
# Host bind-mount for per-trace git workdirs (code-aware workflows). Mounted as `/app/codeflow/workdir`
# inside both api and worker containers — point Working Directory Root in GitHostSettings at
# `/app/codeflow/workdir` (or a subdirectory) so the path resolves identically for both processes.
# The host directory must be owned by UID 1654 (APP_UID baked into the api/worker images):
#   sudo mkdir -p /opt/codeflow/workdirs && sudo chown 1654:1654 /opt/codeflow/workdirs
CODEFLOW_WORKDIRS_DIR=/opt/codeflow/workdirs
# Host bind-mount for per-conversation assistant workspaces (homepage AI assistant). Mounted as
# `/app/codeflow/assistant` inside the api container only (the worker doesn't host the assistant).
# The host directory must be owned by UID 1654 (APP_UID baked into the api image):
#   sudo mkdir -p /opt/codeflow/assistant && sudo chown 1654:1654 /opt/codeflow/assistant
CODEFLOW_ASSISTANT_DIR=/opt/codeflow/assistant

# --- sc-535: sandbox controller deploy (epic 526). ---
# Backend selection: SandboxController routes /run through the controller; Docker
# is the rollback path that re-enables the legacy CLI runner.
CODEFLOW_CONTAINER_BACKEND=SandboxController

# Per-job HTTP timeout the api/worker apply when calling the controller. Should
# be larger than the largest per-job timeout the controller will honour.
CODEFLOW_CONTAINER_REQUEST_TIMEOUT_SECONDS=1800

# Per-host docker group gid. The deploy workflow appends this on the host via
# `getent group docker | cut -d: -f3` — keeping it here makes the example
# self-renderable for `docker compose config`. Replace with the real gid on
# the box (or remove the line and let the deploy workflow handle it).
DOCKER_GID=999

# Host paths for the sandbox-controller's config + per-component mTLS material.
# The deploy/sandbox-controller/scripts/bootstrap-ca.sh script writes here.
CODEFLOW_CFSC_CONFIG_DIR=/opt/codeflow/cfsc/config
CODEFLOW_CFSC_CLIENT_DIR=/opt/codeflow/cfsc-client/api
CODEFLOW_CFSC_CLIENT_WORKER_DIR=/opt/codeflow/cfsc-client/worker
