{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "codeflow-ui": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "cf",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/codeflow-ui",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "editor.main.css",
                "input": "node_modules/monaco-editor/min/vs/editor",
                "output": "assets/monaco-editor/vs/editor"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "loader": {
              ".ttf": "file"
            }
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "optimization": true,
              "sourceMap": false,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "650kB",
                  "maximumError": "800kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "160kB",
                  "maximumError": "200kB"
                }
              ]
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "codeflow-ui:build:development",
            "proxyConfig": "proxy.conf.json",
            "port": 4200
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "codeflow-ui:build:development",
            "tsConfig": "tsconfig.spec.json",
            "runner": "vitest",
            "include": [
              "src/**/*.spec.ts"
            ],
            "providersFile": "src/test-providers.ts",
            "codeCoverageReporters": [
              "text-summary",
              "json-summary",
              "html",
              "lcov"
            ],
            "codeCoverageExclude": [
              "src/main.ts",
              "src/app/app.config.ts",
              "src/app/app.routes.ts",
              "src/app/pages/workflows/editor/workers/**/*.ts"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
